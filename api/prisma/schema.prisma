generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum EstadoTenant {
  ACTIVA
  SUSPENDIDA
  CANCELADA
  TRIAL
}

enum EstadoUsuario {
  PENDIENTE
  ACTIVO
  SUSPENDIDO
  INACTIVO
}

enum Rol {
  SUPER_ADMIN
  ADMIN
  SENIOR
  JUNIOR
}

enum AccionAudit {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

// ─── Models ──────────────────────────────────────────────────

model CatalogoPlan {
  plan                Plan     @id
  limite_usuarios     Int
  limite_propiedades  Int
  tiene_correo        Boolean  @default(false)
  tiene_campanas      Boolean  @default(false)
  tiene_portal        Boolean  @default(false)
  tiene_sitio_propio  Boolean  @default(false)
  tiene_integraciones Boolean  @default(false)
  updated_at          DateTime @updatedAt

  @@map("catalogo_planes")
}

model Tenant {
  id               String        @id @default(uuid())
  nombre           String
  logo_url         String?
  plan             Plan          @default(FREE)
  moneda           String        @default("GTQ")
  zona_horaria     String        @default("America/Guatemala")
  limite_usuarios  Int           @default(10)
  limite_propiedades Int         @default(100)
  estado           EstadoTenant  @default(ACTIVA)
  trial_hasta      DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  usuarios         User[]
  config_seguridad     ConfigSeguridad?
  config_integraciones ConfigIntegraciones?
  config_portal        ConfigPortal?
  audit_logs       AuditLog[]
  propiedades      Propiedad[]
  propietarios     Propietario[]
  clientes         Cliente[]
  notificaciones      Notificacion[]
  meta_publicaciones  MetaPublicacion[]

  @@map("tenants")
}

model ConfigIntegraciones {
  id        String @id @default(uuid())
  tenant_id String @unique

  // ── Email (Resend) ────────────────────────────
  resend_api_key String?
  email_from     String?

  // ── WhatsApp Business Cloud API ───────────────
  whatsapp_token           String?
  whatsapp_phone_number_id String?

  // ── Meta Graph API (Facebook / Instagram) ─────
  meta_page_token  String?
  meta_page_id     String?
  meta_ig_user_id  String?

  // ── Zoom Server-to-Server OAuth ───────────────
  zoom_account_id    String?
  zoom_client_id     String?
  zoom_client_secret String?

  // ── DocuSign JWT ──────────────────────────────
  docusign_integration_key String?
  docusign_account_id      String?
  docusign_user_id         String?
  docusign_rsa_private_key String?
  docusign_base_url        String?

  // ── Sindicación portales externos ─────────────
  encuentra24_api_key String?
  ml_access_token     String?

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  updated_at DateTime @updatedAt

  @@map("config_integraciones")
}

model ConfigPortal {
  id        String @id @default(uuid())
  tenant_id String @unique

  // ── Identidad de la empresa ───────────────────
  nombre_empresa   String?
  slogan           String?
  email_contacto   String?
  telefono         String?
  whatsapp         String?
  direccion        String?
  horario_atencion String?

  // ── Dominio y acceso ──────────────────────────
  dominio_personalizado String?  @unique
  subdominio            String?  @unique
  portal_activo         Boolean  @default(true)

  // ── Apariencia ────────────────────────────────
  favicon_url      String?
  imagen_hero      String?
  titulo_hero      String?
  descripcion_hero String?
  footer_texto     String?

  // ── SEO ───────────────────────────────────────
  seo_titulo      String?
  seo_descripcion String?
  seo_keywords    String?

  // ── Chatbot ───────────────────────────────────
  chatbot_activo             Boolean @default(true)
  chatbot_mensaje_bienvenida String?

  // ── Analytics ─────────────────────────────────
  google_analytics_id String?
  facebook_pixel_id   String?

  // ── Mapa ──────────────────────────────────────
  mapbox_token_publico String?
  mapa_lat_default     Float?
  mapa_lng_default     Float?
  mapa_zoom_default    Int?     @default(12)

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  updated_at DateTime @updatedAt

  @@map("config_portal")
}

model User {
  id                  String        @id @default(uuid())
  tenant_id           String
  email               String
  password_hash       String
  nombre              String
  rol                 Rol
  estado              EstadoUsuario @default(PENDIENTE)
  id_supervisor       String?
  totp_secret         String?
  totp_habilitado     Boolean       @default(false)
  intentos_login      Int           @default(0)
  bloqueado_hasta     DateTime?
  ultimo_login        DateTime?
  password_changed_at DateTime?
  password_history    Json?
  activation_token    String?       @unique
  activation_expires  DateTime?
  reset_token         String?       @unique
  reset_token_expires DateTime?
  tema                String        @default("oscuro")
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  tenant       Tenant    @relation(fields: [tenant_id], references: [id])
  supervisor   User?     @relation("Jerarquia", fields: [id_supervisor], references: [id])
  subordinados User[]    @relation("Jerarquia")
  sessions     Session[]
  propiedades_asignadas Propiedad[]     @relation("PropiedadAgente")
  clientes_asignados    Cliente[]       @relation("ClienteAgente")
  interacciones         Interaccion[]       @relation("InteraccionUsuario")
  visitas               Visita[]            @relation("VisitaAgente")
  meta_publicaciones    MetaPublicacion[]   @relation("UserMeta")

  @@unique([tenant_id, email])
  @@map("users")
}

model Session {
  id            String   @id @default(uuid())
  user_id       String
  tenant_id     String
  refresh_token String   @unique
  ip_address    String
  user_agent    String?
  expires_at    DateTime
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("sessions")
}

model AuditLog {
  id             String      @id @default(uuid())
  tenant_id      String
  user_id        String
  nombre_usuario String
  accion         AccionAudit
  modulo         String
  entidad        String
  entidad_id     String?
  ip_address     String
  user_agent     String?
  payload_cambio Json?
  created_at     DateTime    @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id, created_at])
  @@index([tenant_id, modulo])
  @@index([tenant_id, user_id])
  @@map("audit_logs")
}

model ConfigSeguridad {
  id                      String  @id @default(uuid())
  tenant_id               String  @unique
  geo_paises              Json?
  ips_permitidas          Json?
  dias_inactividad_lead   Int     @default(21)
  senior_puede_ver_upline Boolean @default(false)
  buffer_entre_citas_min  Int     @default(30)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@map("config_seguridad")
}

// ─── Fase 2: Enums ──────────────────────────────────────────

enum TipoPropiedad {
  CASA
  APARTAMENTO
  TERRENO
  LOCAL_COMERCIAL
  OFICINA
  BODEGA
  FINCA
  EDIFICIO
  OTRO
}

enum TipoGestion {
  VENTA
  RENTA
  AMBAS
}

enum EstadoPropiedad {
  BORRADOR
  DISPONIBLE
  RESERVADA
  EN_NEGOCIACION
  VENDIDA
  RENTADA
  SUSPENDIDA
}

enum TipoDocumento {
  ESCRITURA
  PLANO
  IUSI
  BOLETO_COMPRAVENTA
  CONTRATO_ARRENDAMIENTO
  DPI_PROPIETARIO
  OTRO
}

// ─── Fase 2: Models ─────────────────────────────────────────

model Propietario {
  id            String   @id @default(uuid())
  tenant_id     String
  nombre        String
  telefono      String?
  email         String?
  dpi           String?
  nit           String?
  direccion     String?
  notas         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenant_id], references: [id])
  propiedades Propiedad[]

  @@unique([tenant_id, dpi])
  @@index([tenant_id])
  @@map("propietarios")
}

model Propiedad {
  id                String          @id @default(uuid())
  tenant_id         String
  codigo            String
  titulo            String
  descripcion       String?
  tipo              TipoPropiedad
  gestion           TipoGestion
  estado            EstadoPropiedad @default(BORRADOR)

  // Precios
  precio_venta      Decimal?        @db.Decimal(14, 2)
  precio_renta      Decimal?        @db.Decimal(14, 2)
  moneda            String          @default("GTQ")
  comision_porcentaje Decimal?      @db.Decimal(5, 2)

  // Ubicación
  pais              String?         @default("Guatemala")
  departamento      String?
  municipio         String?
  zona              String?
  direccion         String?
  latitud           Decimal?        @db.Decimal(10, 7)
  longitud          Decimal?        @db.Decimal(10, 7)

  // Características
  area_terreno_m2   Decimal?        @db.Decimal(12, 2)
  area_construccion_m2 Decimal?     @db.Decimal(12, 2)
  habitaciones      Int?
  banos             Int?
  parqueos          Int?
  niveles           Int?
  ano_construccion  Int?
  amenidades        Json?

  // Relaciones
  propietario_id    String?
  agente_id         String?

  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  tenant      Tenant              @relation(fields: [tenant_id], references: [id])
  propietario Propietario?        @relation(fields: [propietario_id], references: [id])
  agente      User?               @relation("PropiedadAgente", fields: [agente_id], references: [id])
  imagenes              PropiedadImagen[]
  documentos            PropiedadDocumento[]
  interesados           ClientePropiedad[]
  meta_publicaciones    MetaPublicacion[]         @relation("PropiedadMeta")
  sindicaciones         SindicacionPublicacion[]
  firma_solicitudes     FirmaSolicitud[]

  @@unique([tenant_id, codigo])
  @@index([tenant_id, estado])
  @@index([tenant_id, tipo])
  @@index([tenant_id, gestion])
  @@index([tenant_id, departamento, municipio])
  @@map("propiedades")
}

model PropiedadImagen {
  id            String   @id @default(uuid())
  propiedad_id  String
  url           String
  nombre        String?
  tipo          String   @default("galeria") // portada | galeria
  orden         Int      @default(0)
  tamano_bytes  Int?
  created_at    DateTime @default(now())

  propiedad Propiedad @relation(fields: [propiedad_id], references: [id], onDelete: Cascade)

  @@index([propiedad_id, orden])
  @@map("propiedad_imagenes")
}

model PropiedadDocumento {
  id              String        @id @default(uuid())
  propiedad_id    String
  tipo            TipoDocumento
  nombre          String
  url             String
  fecha_emision   DateTime?
  fecha_vencimiento DateTime?
  notas           String?
  tamano_bytes    Int?
  created_at      DateTime      @default(now())

  propiedad Propiedad @relation(fields: [propiedad_id], references: [id], onDelete: Cascade)

  @@index([propiedad_id])
  @@map("propiedad_documentos")
}

// ─── Notificaciones ─────────────────────────────────────────

enum TipoNotificacion {
  DOCUMENTO_POR_VENCER
  DOCUMENTO_VENCIDO
  SISTEMA
  MATCH_PROPIEDAD
  VISITA_AGENDADA
  LEAD_INACTIVO
}

model Notificacion {
  id         String           @id @default(uuid())
  tenant_id  String
  user_id    String
  tipo       TipoNotificacion
  titulo     String
  mensaje    String
  leida      Boolean          @default(false)
  entidad    String?
  entidad_id String?
  created_at DateTime         @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([user_id, leida])
  @@index([tenant_id, created_at])
  @@map("notificaciones")
}

// ─── Sprint 4: Enums ────────────────────────────────────────

enum OrigenCliente {
  PORTAL_WEB
  REFERIDO
  LLAMADA
  WHATSAPP
  REDES_SOCIALES
  FERIA
  OTRO
}

enum EstadoInteres {
  NUEVO
  CONTACTADO
  INTERESADO
  EN_NEGOCIACION
  GANADO
  PERDIDO
}

enum NivelInteres {
  BAJO
  MEDIO
  ALTO
  MUY_ALTO
}

enum TipoInteraccion {
  LLAMADA
  VISITA
  MENSAJE
  NOTA
  WHATSAPP
  EMAIL
}

enum ResultadoInteraccion {
  POSITIVO
  NEUTRO
  NEGATIVO
  SIN_RESPUESTA
}

enum EstadoVisita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  REALIZADA
}

// ─── Sprint 4: Models ───────────────────────────────────────

model Cliente {
  id               String          @id @default(uuid())
  tenant_id        String
  nombre           String
  email            String?
  telefono         String?
  dpi              String?
  origen           OrigenCliente   @default(OTRO)
  notas            String?
  agente_id        String?

  // Preferencias de búsqueda (para matching)
  tipo_interes     TipoPropiedad?
  gestion_interes  TipoGestion?
  presupuesto_max  Decimal?        @db.Decimal(14, 2)
  zona_interes     String?
  habitaciones_min Int?

  // Portal self-registration
  portal_verificado  Boolean   @default(false)
  activation_token   String?   @unique
  activation_expires DateTime?

  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  tenant    Tenant             @relation(fields: [tenant_id], references: [id])
  agente    User?              @relation("ClienteAgente", fields: [agente_id], references: [id])
  intereses ClientePropiedad[]

  @@unique([tenant_id, email])
  @@index([tenant_id])
  @@index([tenant_id, origen])
  @@map("clientes")
}

model ClientePropiedad {
  id              String        @id @default(uuid())
  cliente_id      String
  propiedad_id    String
  estado          EstadoInteres @default(NUEVO)
  nivel_interes   NivelInteres  @default(MEDIO)
  presupuesto     Decimal?      @db.Decimal(14, 2)
  notas           String?
  motivo_perdida  String?
  fecha_contacto  DateTime?
  fecha_cierre    DateTime?
  precio_cierre   Decimal?      @db.Decimal(14, 2)
  comision_calculada Decimal?   @db.Decimal(14, 2)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  cliente       Cliente        @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  propiedad     Propiedad      @relation(fields: [propiedad_id], references: [id], onDelete: Cascade)
  interacciones Interaccion[]
  visitas       Visita[]

  @@unique([cliente_id, propiedad_id])
  @@index([propiedad_id, estado])
  @@index([estado])
  @@index([estado, fecha_cierre])
  @@map("cliente_propiedades")
}

model Interaccion {
  id           String               @id @default(uuid())
  interes_id   String
  usuario_id   String
  tipo         TipoInteraccion
  resultado    ResultadoInteraccion @default(NEUTRO)
  notas        String?
  duracion_min Int?
  fecha        DateTime             @default(now())
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt

  interes  ClientePropiedad @relation(fields: [interes_id], references: [id], onDelete: Cascade)
  usuario  User             @relation("InteraccionUsuario", fields: [usuario_id], references: [id])

  @@index([interes_id, fecha])
  @@index([usuario_id, fecha])
  @@map("interacciones")
}

model Visita {
  id           String       @id @default(uuid())
  interes_id   String
  agente_id    String
  fecha_inicio DateTime
  fecha_fin    DateTime
  ubicacion    String?
  notas        String?
  estado       EstadoVisita @default(PENDIENTE)

  reporte_notas           String?
  reporte_nivel_interes   String?
  reporte_reaccion        String?
  reporte_siguiente_paso  String?
  reporte_fecha           DateTime?

  // Client reschedule link
  reschedule_token           String?   @unique
  reschedule_expires         DateTime?
  reschedule_propuesta_inicio DateTime?
  reschedule_propuesta_fin   DateTime?
  reschedule_notas           String?
  reschedule_solicitado_at   DateTime?

  // HU-12.02: Videollamada Zoom
  zoom_meeting_id String?
  zoom_join_url   String?

  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  interes ClientePropiedad @relation(fields: [interes_id], references: [id], onDelete: Cascade)
  agente  User             @relation("VisitaAgente", fields: [agente_id], references: [id])

  @@index([agente_id, fecha_inicio])
  @@index([interes_id])
  @@map("visitas")
}

// ─── Brochure async jobs ─────────────────────────────────────

enum BrochureJobStatus {
  PROCESANDO
  LISTO
  ERROR
}

model BrochureJob {
  id           String            @id
  propiedad_id String
  tenant_id    String
  user_id      String
  status       BrochureJobStatus @default(PROCESANDO)
  url          String?
  error        String?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt
  descargas    BrochureDescarga[]

  @@index([propiedad_id, tenant_id])
  @@map("brochure_jobs")
}

model BrochureDescarga {
  id            String   @id @default(uuid())
  job_id        String
  tenant_id     String
  user_id       String
  ip            String?
  downloaded_at DateTime @default(now())

  job BrochureJob @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([tenant_id, downloaded_at])
  @@map("brochure_descargas")
}

// ─── Email campañas ──────────────────────────────────────────

enum EstadoCampana {
  BORRADOR
  ENVIANDO
  ENVIADA
  FALLIDA
}

model EmailPlantilla {
  id          String         @id @default(uuid())
  tenant_id   String
  nombre      String
  asunto      String
  cuerpo_html String
  variables   String[]
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  campanas    EmailCampana[]

  @@index([tenant_id])
  @@map("email_plantillas")
}

model EmailCampana {
  id             String         @id @default(uuid())
  tenant_id      String
  nombre         String
  plantilla_id   String
  plantilla      EmailPlantilla @relation(fields: [plantilla_id], references: [id])
  filtro_rol     Rol[]
  variables_data Json           @default("{}")
  estado         EstadoCampana  @default(BORRADOR)
  total_enviados Int            @default(0)
  enviada_at     DateTime?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  eventos        EmailEvento[]

  @@index([tenant_id, created_at])
  @@map("email_campanas")
}

// ─── WhatsApp envíos ─────────────────────────────────────────

model WhatsappEnvio {
  id               String   @id @default(uuid())
  tenant_id        String
  propiedad_id     String
  user_id          String
  telefono_destino String
  mensaje          String?
  status           String   @default("ENVIADO") // ENVIADO | FALLIDO | LINK
  waba_message_id  String?
  error            String?
  enviado_at       DateTime @default(now())

  @@index([tenant_id, propiedad_id])
  @@index([tenant_id, enviado_at(sort: Desc)])
  @@map("whatsapp_envios")
}

// ─── Email tracking ──────────────────────────────────────────

model EmailEvento {
  id              String        @id @default(uuid())
  tenant_id       String
  notificacion_id String?
  campana_id      String?
  campana         EmailCampana? @relation(fields: [campana_id], references: [id])
  destinatario    String
  tipo            TipoNotificacion
  enviado_at      DateTime      @default(now())
  abierto_at      DateTime?
  primer_clic_at  DateTime?

  @@index([tenant_id, enviado_at])
  @@index([campana_id])
  @@map("email_eventos")
}

// ─── HU-12.01: Sindicación portales externos ────────────────

enum PortalExterno {
  ENCUENTRA24
  MERCADOLIBRE
}

enum EstadoSindicacion {
  PENDIENTE
  PUBLICADO
  ERROR
  RETIRADO
}

model SindicacionPublicacion {
  id           String            @id @default(uuid())
  tenant_id    String
  propiedad_id String
  portal       PortalExterno
  estado       EstadoSindicacion @default(PENDIENTE)
  external_id  String?
  external_url String?
  error_msg    String?
  publicado_at DateTime?
  retirado_at  DateTime?
  created_at   DateTime          @default(now())
  updated_at   DateTime          @updatedAt

  propiedad Propiedad @relation(fields: [propiedad_id], references: [id], onDelete: Cascade)

  @@unique([propiedad_id, portal])
  @@index([tenant_id, portal])
  @@map("sindicacion_publicaciones")
}

// ─── HU-12.02: Firma digital ─────────────────────────────────

enum EstadoFirma {
  PENDIENTE
  ENVIADO
  COMPLETADO
  DECLINADO
  VENCIDO
}

model FirmaSolicitud {
  id              String      @id @default(uuid())
  tenant_id       String
  propiedad_id    String
  agente_id       String
  firmante_nombre String
  firmante_email  String
  estado          EstadoFirma @default(PENDIENTE)
  envelope_id     String?
  signing_url     String?
  completado_at   DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  propiedad Propiedad @relation(fields: [propiedad_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, estado])
  @@index([propiedad_id])
  @@map("firma_solicitudes")
}

// ─── Sprint 7+: Meta (Facebook / Instagram) ──────────────────

enum MetaPlataforma {
  FACEBOOK
  INSTAGRAM
  AMBAS
}

enum MetaEstado {
  BORRADOR
  PROGRAMADA
  PUBLICADA
  FALLIDA
}

model MetaPublicacion {
  id              String         @id @default(uuid())
  tenant_id       String
  propiedad_id    String?
  agente_id       String
  plataforma      MetaPlataforma
  mensaje         String
  imagen_url      String?
  estado          MetaEstado     @default(BORRADOR)
  programado_para DateTime?
  publicado_at    DateTime?
  fb_post_id      String?
  ig_post_id      String?
  error_msg       String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  tenant    Tenant     @relation(fields: [tenant_id], references: [id])
  propiedad Propiedad? @relation("PropiedadMeta", fields: [propiedad_id], references: [id], onDelete: SetNull)
  agente    User       @relation("UserMeta", fields: [agente_id], references: [id])

  @@index([tenant_id, estado])
  @@index([tenant_id, created_at])
  @@map("meta_publicaciones")
}

