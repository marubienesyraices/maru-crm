{
  "name": "gestprop-crm",
  "version": "0.1.0",
  "private": true,
  "description": "GestProp — CRM Inmobiliario",
  "workspaces": [
    "shared",
    "api",
    "web",
    "portal",
    "mcp-drawio"
  ],
  "scripts": {
    "dev:api":    "npm run dev -w api",
    "dev:web":    "npm run dev -w web",
    "dev:portal": "npm run dev -w portal",
    "build:api":  "npm run build -w api",
    "build:web":  "npm run build -w web",
    "build:portal": "npm run build -w portal",
    "lint":       "npm run lint -w api; npm run lint -w web",
    "test":       "npm run test -w api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
