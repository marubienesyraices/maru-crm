{
  "name": "maru-crm",
  "version": "0.1.0",
  "private": true,
  "description": "CRM Inmobiliario Maru Bienes y Raíces",
  "workspaces": [
    "shared",
    "api",
    "web"
  ],
  "scripts": {
    "dev:api": "npm run dev -w api",
    "dev:web": "npm run dev -w web",
