# ── Producción — copiar a .env.production y completar valores ────────────────
# Usar: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ── Base de datos ────────────────────────────────────────────────────────────
DB_USER=maru_app
DB_PASSWORD=CAMBIAR_contrasena_segura_aqui
DB_NAME=maru_crm

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_redis_password_aqui

# ── JWT (generar con: openssl rand -hex 32) ──────────────────────────────────
JWT_ACCESS_SECRET=CAMBIAR_jwt_access_secret_64chars_minimo
JWT_REFRESH_SECRET=CAMBIAR_jwt_refresh_secret_64chars_minimo

# ── URLs públicas ────────────────────────────────────────────────────────────
APP_URL=https://api.tudominio.com
FRONTEND_URL=https://crm.tudominio.com

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=maru-crm-prod
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Maru CRM <noreply@tudominio.com>

# ── Mapbox ───────────────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxx
MAPBOX_TOKEN=sk.xxxxxxxxxxxx

# ── Portal público ───────────────────────────────────────────────────────────
PORTAL_TENANT_ID=

# ── Sentry (https://sentry.io) ───────────────────────────────────────────────
SENTRY_DSN_API=https://xxx@oXXX.ingest.sentry.io/XXXXXX
SENTRY_DSN_WEB=https://xxx@oXXX.ingest.sentry.io/XXXXXX
SENTRY_DSN_PORTAL=https://xxx@oXXX.ingest.sentry.io/XXXXXX
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
SENTRY_ORG=maru-bienes-y-raices
SENTRY_PROJECT_API=maru-crm-api
SENTRY_PROJECT_WEB=maru-crm-web
