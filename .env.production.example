# ── Producción — copiar a .env.production y completar valores ────────────────
# Usar: docker compose -f docker-compose.prod.yml --env-file .env.production up -d




# ── Base de datos (generar con: openssl rand -hex 32)   ──────────────────────
DB_USER=gestprop_app
DB_PASSWORD=CAMBIAR_contrasena_segura_aqui
DB_NAME=gestprop_crm

# ── Redis <generar: openssl rand -base64 32> ─────────────────────────────────
REDIS_PASSWORD=CAMBIAR_contrasena_segura_aqui

# ── JWT (generar con: openssl rand -hex 32) ──────────────────────────────────
JWT_ACCESS_SECRET=CAMBIAR_jwt_access_secret_64chars_minimo
JWT_REFRESH_SECRET=CAMBIAR_jwt_refresh_secret_64chars_minimo

# ── URLs públicas ────────────────────────────────────────────────────────────
APP_URL=https://api.gestprop.net
FRONTEND_URL=https://crm.gestprop.net
PORTAL_URL=https://www.gestprop.net



# ── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gestprop-prod
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Email / Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=GestProp CRM <noreplyQA@gestprop.net>

# ── Encryption (generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
MASTER_ENCRYPTION_KEY=CAMBIAR_contrasena_segura_aqui

# ── Mapbox ───────────────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxx
MAPBOX_TOKEN=sk.xxxxxxxxxxxx

# ── Google Maps (ver Paso 17) ────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIzaSyANIFsoiu3RcM9HQEaxfXIVUNKPLzLygwo

# ── Portal público ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gestprop.net
PORTAL_TENANT_ID=

# ── WhatsApp (ver Paso 18) — dejar vacío si no se usa ────────────────
# WHATSAPP_API_TOKEN=EAAxxxxxxxx
# WHATSAPP_PHONE_NUMBER_ID=123456789012345

# ── Meta Facebook/Instagram (ver Paso 19) — dejar vacío si no se usa ─
# META_PAGE_ACCESS_TOKEN=EAAxxxxxxxx
# META_PAGE_ID=123456789012345
# META_IG_USER_ID=987654321098765

# ── Zoom (ver Paso 20) — dejar vacío si no se usa ────────────────────
# ZOOM_ACCOUNT_ID=xxxxxxxxxx
# ZOOM_CLIENT_ID=xxxxxxxxxx
# ZOOM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxx

# ── DocuSign (ver Paso 21) — dejar vacío si no se usa ────────────────
