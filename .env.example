# Database
DATABASE_URL="postgresql://gestprop_admin:gestprop_secret_2026@localhost:5432/gestprop_crm?schema=public"

# Encryption — clave maestra para cifrar credenciales de integraciones en DB
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY="cambia-esto-genera-64-hex-chars-con-el-comando-de-arriba"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-32chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-32chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
VITE_API_URL="http://localhost:3000"
# URL pública del servidor API (se usa en tracking de emails)
APP_URL="http://localhost:3000"

# Cloudflare R2 (optional — leave blank to use local disk storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Email / Resend (optional — leave blank to disable email notifications)
# Get your API key at https://resend.com
RESEND_API_KEY=""
EMAIL_FROM="GestProp CRM <noreply@tudominio.com>"

# Mapbox — get token at https://account.mapbox.com
# VITE_MAPBOX_TOKEN: expuesto al navegador (mapa estático en formulario propiedad y portal)
# MAPBOX_TOKEN: solo servidor (auto-geocodificación al crear/editar propiedades)
VITE_MAPBOX_TOKEN=""
MAPBOX_TOKEN=""

# Google Maps — get key at https://console.cloud.google.com (Geocoding API)
# VITE_GOOGLE_MAPS_API_KEY: expuesto al navegador (geocodificación en formulario propiedad)
VITE_GOOGLE_MAPS_API_KEY=""

# Portal público — UUID del tenant cuyas propiedades se muestran en /portal
# Dejar vacío para mostrar propiedades de todos los tenants
PORTAL_TENANT_ID=""
# URL pública del portal Next.js (usado en emails de verificación de cuenta de cliente)
# Si se configura, el enlace de confirmación apunta al portal en lugar del CRM web
PORTAL_URL="http://localhost:3001"
# Variables del portal Next.js (prefijo NEXT_PUBLIC_ para ser accesibles en el browser)
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="GestProp"
NEXT_PUBLIC_COMPANY_EMAIL=""
NEXT_PUBLIC_WHATSAPP=""
NEXT_PUBLIC_SITE_URL="https://gestprop.net"  # URL pública del portal (usada en sitemap.xml y robots.txt)
PORTAL_TENANT_ID=""  # UUID del tenant que muestra el portal público (empresa 0). Vacío = primer tenant creado

# WhatsApp Business Cloud API (opcional — dejar vacío para usar fallback wa.me link)
# Crear cuenta en https://developers.facebook.com/apps y configurar WhatsApp Business
# WHATSAPP_PHONE_NUMBER_ID: ID del número de teléfono en Meta Business (ej: 123456789012345)
# WHATSAPP_API_TOKEN: Token de acceso permanente del sistema
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Meta Graph API — publicación en Facebook e Instagram (opcional)
# Obtener en https://developers.facebook.com/apps → tu app → herramientas → explorador de API
# META_PAGE_ACCESS_TOKEN: Page Access Token de larga duración de la página de Facebook
# META_PAGE_ID: ID numérico de la página de Facebook (ej: 123456789012345)
# META_IG_USER_ID: ID de la cuenta de Instagram Business vinculada a la página
META_PAGE_ACCESS_TOKEN=""
META_PAGE_ID=""
META_IG_USER_ID=""

# HU-12.01: Sindicación portales externos (opcional)
# Encuentra24 — API de listado de propiedades en Guatemala
ENCUENTRA24_API_KEY=""
ENCUENTRA24_API_URL="https://api.encuentra24.com/v1"
# MercadoLibre — App OAuth: https://developers.mercadolibre.com/apps
ML_ACCESS_TOKEN=""

# HU-12.02: DocuSign — firma digital (opcional)
# Crear app en https://developers.docusign.com → Apps and Keys
# Demo: https://demo.docusign.net/restapi  /  Producción: https://www.docusign.net/restapi
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_CLIENT_SECRET=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_USER_ID=""
DOCUSIGN_RSA_PRIVATE_KEY=""
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"

# HU-12.02: Zoom — videollamadas en visitas (opcional)
# Crear Server-to-Server OAuth app en https://marketplace.zoom.us/develop/create
ZOOM_ACCOUNT_ID=""
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# Sentry — monitoreo de errores y performance (opcional en desarrollo)
# Crear proyecto en https://sentry.io y copiar el DSN
SENTRY_DSN=""
VITE_SENTRY_DSN=""
