skinparam cloudBackgroundColor #C5E0F5
skinparam cloudBorderColor     #1168BD
skinparam cloudFontColor       #000000
skinparam cloudFontSize        10

skinparam rectangleBackgroundColor transparent
skinparam rectangleBorderColor     #1168BD
skinparam rectangleFontColor       #000000
skinparam rectangleFontSize        10

skinparam arrowColor    #1168BD
skinparam arrowFontSize 10

skinparam NoteBackgroundColor #EEF5FF
skinparam NoteBorderColor     #1168BD
skinparam NoteFontSize        9

title Diagrama de Red y TopologГ­a de Seguridad вЂ” GestPro CRM

rectangle "Clientes" as zClientes {
  actor "Navegador\n(CRM В· Portal)" as browser
  actor "App MГіvil\n(Expo / React Native)" as mobile
}

cloud "Cloudflare  (CDN + WAF)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDDoS L3/L4/L7  В·  Bot Fight Mode\nWAF Rules  В·  Rate Limiting\nDNS Proxy  В·  IP Geoblocking" as cf

node "VPS В· Ubuntu 22.04  вЂ”  Docker Compose" as vps {

  rectangle "Red Docker: external  (bridge вЂ” acceso pГєblico)" as netExt {
    component "Nginx 1.27-alpine\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\npuertos :80 / :443 expuestos\nTLS 1.2 / TLS 1.3  В·  HSTS\nHTTP в†’ HTTPS redirect\nX-Frame-Options DENY\nX-Content-Type-Options nosniff\nContent-Security-Policy\nserver_tokens off  В·  max body 25 MB" as nginx
  }

  rectangle "Red Docker: internal  (bridge вЂ” aislada, sin internet)" as netInt {
    component "API  NestJS\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n:3000 (interno)\nJWT  В·  RolesGuard\nVisibilityGuard  В·  Throttle\nAuditInterceptor  В·  RLS" as api
    component "CRM Web\nReact + Vite\n:80 (interno)" as web
    component "Portal SSR\nNext.js 14\n:3001 (interno)" as portal
    component "Worker BullMQ\n(sin puerto expuesto)\nPDF В· Posts sociales" as worker
  }

  rectangle "Capa de Datos  (red interna вЂ” nunca expuesta a internet)" as netData {
    database "PostgreSQL 16\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n:5432 (interno)\nRLS por tenant\nRol gestpro_app\naudit_logs inmutable\nBackup diario" as pg
    database "Redis 7\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n:6379 (interno)\nPassword requerida\nmaxmemory 256 MB\nBullMQ + BI Cache" as redis
  }
}

browser  -down-> cf     : HTTPS 443
mobile   -down-> cf     : HTTPS 443

cf       -down-> nginx  : HTTPS (CF-Connecting-IP)

nginx    -down-> api    : HTTP/1.1 В· WS  :3000
nginx    -down-> web    : HTTP  :80
nginx    -down-> portal : HTTP/1.1 В· WS  :3001

api      -down-> pg     : TCP :5432
api      -down-> redis  : TCP :6379
worker   -down-> pg     : TCP :5432
worker   -down-> redis  : TCP :6379



@enduml
