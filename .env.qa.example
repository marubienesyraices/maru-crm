# ══════════════════════════════════════════════════════════════════════
# GestProp CRM — QA / Staging
# ══════════════════════════════════════════════════════════════════════
# Copiar a .env.qa y completar valores reales
# Uso: docker compose -f docker-compose.qa.yml --env-file .env.qa up -d

# ── Base de datos ────────────────────────────────────────────────────
DB_USER=gestprop_admin
DB_PASSWORD=CAMBIAR_qa_password_aqui
DB_NAME=gestprop_crm_qa

# Rol restringido con RLS activo (crear en el servidor QA igual que en prod)
# Ver: api/prisma/sql/rls_policies/
DB_APP_USER=gestprop_app
DB_APP_PASSWORD=CAMBIAR_qa_app_password_aqui

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=CAMBIAR_redis_qa_password_aqui

# ── JWT (generar: openssl rand -hex 32) ─────────────────────────────
JWT_ACCESS_SECRET=CAMBIAR_jwt_access_secret_qa
JWT_REFRESH_SECRET=CAMBIAR_jwt_refresh_secret_qa

# ── URLs públicas ────────────────────────────────────────────────────
APP_URL=https://api-qa.gestprop.net
FRONTEND_URL=https://crm-qa.gestprop.net 
PORTAL_URL=https://qa.gestprop.net

# ── Cloudflare R2 ────────────────────────────────────────────────────
# Usar bucket separado para aislar archivos QA de producción
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gestprop-qa
R2_PUBLIC_URL=https://cdn-qa.gestprop.net

# ── Email / Resend ───────────────────────────────────────────────────
# Usar dominio de prueba o el mismo con FROM distinto para identificar correos QA
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=GestProp QA <qa@gestprop.net>

# ── Encryption (generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ──
MASTER_ENCRYPTION_KEY=CAMBIAR_64_hex_chars_aqui

# ── Mapbox ───────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=pk.xxxxxxxxxxxx
MAPBOX_TOKEN=pk.xxxxxxxxxxxx

# ── Google Maps ──────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ── Portal público ───────────────────────────────────────────────────
PORTAL_TENANT_ID=
NEXT_PUBLIC_SITE_URL=https://qa.gestprop.net

# ── WhatsApp — dejar vacío si no se prueba en QA ────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Meta Facebook/Instagram — dejar vacío si no se prueba en QA ─────
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# ── Zoom — dejar vacío si no se prueba en QA ────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── DocuSign — usar entorno demo en QA ──────────────────────────────
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_USER_ID=
DOCUSIGN_RSA_PRIVATE_KEY=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# ── Sentry — proyecto separado para QA ──────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_DSN_PORTAL=
